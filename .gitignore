# ================================
# OhMyOpenSource! Website — .gitignore
# ================================

# ================================
# Dependencies
# ================================
/node_modules
/.pnp
.pnp.*

.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.pnpm-store/
pnpm-lock.yaml.bak

# ================================
# Next.js
# ================================
/.next/
/out/
/build

# ================================
# Testing
# ================================
/coverage
/.nyc_output

# ================================
# Environment variables
# ================================
.env
.env.*
!.env.example

# ================================
# TypeScript
# ================================
*.tsbuildinfo
next-env.d.ts

# ================================
# Debug logs
# ================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ================================
# OS generated
# ================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ================================
# Certificates
# ================================
*.pem
*.key
*.crt

# ================================
# VS Code
# ================================
.vscode/*
.vscode/extensions.json
.vscode/settings.json

# ================================
# JetBrains / IntelliJ
# ================================
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# ================================
# Vercel
# ================================
.vercel

# ================================
# Misc tooling
# ================================
.turbo/
.cache/
*.swp
*.swo
*~
